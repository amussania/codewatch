# CODEWATCH Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git (it's in .gitignore)
# Author: Kimi Build Agent | Date: 2026-05-17

# ═══════════════════════════════════════════════════════════════
# Supabase (Required)
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ═══════════════════════════════════════════════════════════════
# Stripe (Required for payments)
# ═══════════════════════════════════════════════════════════════

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ═══════════════════════════════════════════════════════════════
# AI Provider (Required for review engine)
# ═══════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=sk-ant-api03-...
# Or use OpenAI:
# OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════
# Upstash Redis (Required for rate limiting)
# ═══════════════════════════════════════════════════════════════

UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ═══════════════════════════════════════════════════════════════
# Resend (Required for transactional emails)
# ═══════════════════════════════════════════════════════════════

RESEND_API_KEY=re_...

# ═══════════════════════════════════════════════════════════════
# Sentry (Required for error tracking)
# ═══════════════════════════════════════════════════════════════

SENTRY_DSN=https://your-dsn.ingest.sentry.io/...

# ═══════════════════════════════════════════════════════════════
# Application (Required)
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_APP_URL=https://codewatch-theta.vercel.app

# ═══════════════════════════════════════════════════════════════
# Optional / Development
# ═══════════════════════════════════════════════════════════════

# NODE_ENV=development
# NEXT_PUBLIC_DEBUG=true
